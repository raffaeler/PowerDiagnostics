{
    "General": {
        "DebuggingSessionsExpirationMinutes": 1,
        "DumpsFolder": "H:\\_dumps",
        "AnalyzerSettings": {
            "ApplyNet10DatasStaticWorkaround": false
        }
    },

    "Mcp": {
        "DefaultPageSize": 10,
        "MaxPageSize": 50,
        "DefaultMaxPaths": 3,
        "MaxPaths": 10,
        "DefaultTopN": 20,
        "MaxInsightEntries": 5,
        "HttpEndpoint": "/mcp"
    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}
