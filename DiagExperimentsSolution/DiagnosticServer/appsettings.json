{
    "General": {
        "DebuggingSessionsExpirationMinutes": 1,
        "DumpsFolder": "H:\\_dumps"
    },

    "Diagnostics": {
        "DeduplicateRegisterRoots": false
    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}
